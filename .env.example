# Required: powers structured note generation (step 2)
# Get one free at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional: model override for the *primary* provider only. Check
# https://ai.google.dev/gemini-api/docs/models for the current model id if
# this default is stale.
GEMINI_MODEL=gemini-2.5-flash

# Optional but recommended: notes generation falls back through
# gemini-2.5-flash -> gemini-2.5-flash-lite -> Groq's Llama 3.3 70B, in that
# order, on quota/rate-limit errors specifically (see src/notesGenerator.js).
# Gemini's free tier caps out fast (~20 requests/day on gemini-2.5-flash);
# without this set, generation just fails once both Gemini quotas are
# exhausted instead of falling through to Groq. Free key at
# https://console.groq.com/keys.
GROQ_API_KEY=

# Optional: only needed for the audio-transcription fallback (step 1b) when a
# video has no captions. Requires yt-dlp to also be installed and on PATH.
OPENAI_API_KEY=
