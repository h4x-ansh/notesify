# Required: powers structured note generation (step 2)
# Get one free at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional: model override. Check https://ai.google.dev/gemini-api/docs/models
# for the current model id if this default is stale.
GEMINI_MODEL=gemini-2.5-flash

# Optional: only needed for the audio-transcription fallback (step 1b) when a
# video has no captions. Requires yt-dlp to also be installed and on PATH.
OPENAI_API_KEY=
