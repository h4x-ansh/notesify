# Used only by `npm run build:mobile` (see package.json) - the Capacitor/
# Android build. Electron's `npm run build` does NOT read this file, so
# these values never affect the desktop app's local-server config.
#
# Copy this to .env.mobile (gitignored) and fill in real values before
# building the APK.

# The live hosted Render backend, not localhost.
NEXT_PUBLIC_API_BASE_URL=https://notesify-3lqb.onrender.com

# Must match API_SHARED_SECRET set in Render's dashboard (see render.yaml
# and server.js's requireApiSecret). Baked into the APK at build time -
# fine for a single-owner app, not real per-user auth. Anyone who decompiles
# the APK can extract this string; treat it as "keeps casual/automated
# abuse off the public URL," not as a real secret boundary.
NEXT_PUBLIC_API_SHARED_SECRET=
